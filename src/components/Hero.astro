---
import { instagramHandle, instagramUrl } from '../data/social';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section id="home" class="hero-wrapper" aria-label="Welcome to Burgerium">
    <div class="bg-layer" aria-hidden="true">
        <img
            src={`${base}/chennai_hero.png`}
            alt=""
            class="parallax-img"
            loading="eager"
            fetchpriority="high"
        />
        <div class="overlay"></div>
    </div>

    <div class="container hero-grid">
        <div class="hero-text">
            <div class="hero-copy-shell">
                <div class="launch-badge slide-in-1">
                    Chennai Launch • Q1 2025
                </div>
                <h1 class="mega-title">
                    <span class="line slide-in-2">Every Bite</span>
                    <span class="line accent slide-in-3">Counts.</span>
                </h1>

                <p class="hero-desc slide-in-4">
                    25 years of craft. House-baked buns. Charcoal-seared patties. Chennai's new burger destination.
                </p>

                <div class="hero-highlights slide-in-5" aria-label="Burgerium highlights">
                    <span>25+ years of burger craft</span>
                    <span>House-baked buns every day</span>
                    <span>Digital menu now live</span>
                </div>

                <div class="hero-actions slide-in-5">
                    <a
                        href={instagramUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="btn-primary hero-cta"
                    >
                        <i class="fab fa-instagram" aria-hidden="true"></i>
                        Follow {instagramHandle}
                    </a>
                    <a href="/menu" class="hero-link">
                        Browse Menu
                        <i class="fas fa-arrow-right" aria-hidden="true"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="hero-visual">
            <div class="circle-bg pulse-anim" aria-hidden="true"></div>
            <div class="visual-stage">
                <img
                    src={`${base}/monster_stack.png`}
                    alt="The Monster Stack - Burgerium's signature multi-patty burger"
                    class="hero-burger float-anim tilt-element"
                    loading="eager"
                />

                <div class="float-card glass-card" aria-hidden="true">
                    <span class="emoji">🔥</span>
                    <div class="card-text">
                        <strong>The Real Deal</strong>
                        <small>Only at Burgerium</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Scroll indicator -->
    <div class="scroll-indicator" aria-hidden="true">
        <div class="mouse">
            <div class="wheel"></div>
        </div>
        <span>Scroll to explore</span>
    </div>
</section>

<style>
    .hero-wrapper {
        position: relative;
        height: 100vh;
        min-height: 700px;
        display: flex;
        align-items: center;
        overflow: hidden;
        isolation: isolate;
        background:
            radial-gradient(circle at 12% 18%, rgba(250, 162, 39, 0.18), transparent 24%),
            radial-gradient(circle at 78% 30%, rgba(250, 162, 39, 0.1), transparent 28%),
            linear-gradient(180deg, #fff6df 0%, #fff2d0 100%);
    }

    .bg-layer {
        position: absolute;
        inset: 0;
        z-index: 0;
        overflow: hidden;
        pointer-events: none;
    }

    .parallax-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        transform: scale(1.04);
        opacity: 0.12;
        filter: saturate(0.8) sepia(0.28) contrast(0.9);
        transition: transform 0.1s ease-out;
    }

    .overlay {
        position: absolute;
        inset: 0;
        background:
            linear-gradient(90deg, rgba(255, 248, 230, 0.96) 0%, rgba(255, 244, 214, 0.92) 45%, rgba(255, 242, 205, 0.52) 72%, rgba(255, 241, 205, 0.22) 100%),
            radial-gradient(circle at 80% 16%, rgba(74, 45, 7, 0.12), transparent 26%);
    }

    .scroll-indicator {
        position: absolute;
        bottom: 2rem;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        opacity: 0;
        animation: fadeInUp 1s ease forwards 1.5s;
        z-index: 2;
    }

    .mouse {
        width: 24px;
        height: 40px;
        border: 2px solid rgba(71, 45, 6, 0.28);
        border-radius: 12px;
        position: relative;
    }

    .wheel {
        width: 4px;
        height: 8px;
        background: var(--brand-orange);
        border-radius: 2px;
        position: absolute;
        top: 8px;
        left: 50%;
        transform: translateX(-50%);
        animation: scrollWheel 2s ease-in-out infinite;
    }

    @keyframes scrollWheel {
        0%, 100% { opacity: 1; top: 8px; }
        50% { opacity: 0.3; top: 20px; }
    }

    @keyframes fadeInUp {
        from { opacity: 0; transform: translateX(-50%) translateY(20px); }
        to { opacity: 1; transform: translateX(-50%) translateY(0); }
    }

    .scroll-indicator span {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: var(--text-muted);
    }

    .hero-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.05fr) minmax(360px, 0.95fr);
        align-items: center;
        width: 100%;
        gap: clamp(2.5rem, 5vw, 6rem);
        padding-top: calc(var(--header-height) + 2.2rem);
        padding-bottom: 7rem;
        position: relative;
        z-index: 1;
    }

    .hero-copy-shell {
        max-width: 42rem;
        padding: clamp(1.8rem, 4vw, 2.8rem);
        background: linear-gradient(145deg, rgba(255, 251, 241, 0.9), rgba(255, 242, 208, 0.78));
        border: 1px solid rgba(96, 61, 10, 0.12);
        border-radius: 34px;
        box-shadow: 0 26px 60px rgba(105, 68, 9, 0.12);
        backdrop-filter: blur(10px);
    }

    .mega-title {
        font-size: clamp(4rem, 8vw, 6.8rem);
        line-height: 0.88;
        margin-bottom: 1.2rem;
        color: var(--text-white);
        letter-spacing: -0.03em;
    }

    .mega-title .line {
        display: block;
    }

    .mega-title .accent {
        color: var(--brand-orange-deep);
        text-shadow: 0 10px 24px rgba(250, 162, 39, 0.18);
    }

    .hero-desc {
        font-size: 1.18rem;
        color: var(--text-gray);
        max-width: 32rem;
        margin-bottom: 1.5rem;
        line-height: 1.6;
    }

    .hero-highlights {
        display: flex;
        flex-wrap: wrap;
        gap: 0.8rem;
        margin-bottom: 2rem;
    }

    .hero-highlights span {
        display: inline-flex;
        align-items: center;
        gap: 0.7rem;
        min-height: 42px;
        padding: 0.65rem 0.95rem;
        border-radius: 999px;
        background: rgba(255, 250, 239, 0.92);
        border: 1px solid var(--line-soft);
        color: var(--text-white);
        font-size: 0.92rem;
        font-weight: 600;
        box-shadow: 0 10px 24px rgba(96, 61, 10, 0.06);
    }

    .hero-highlights span::before {
        content: '';
        width: 9px;
        height: 9px;
        border-radius: 50%;
        background: var(--brand-orange);
        box-shadow: 0 0 0 4px rgba(250, 162, 39, 0.16);
        flex: 0 0 9px;
    }

    .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        align-items: center;
    }

    .hero-cta {
        min-height: 58px;
        justify-content: center;
        gap: 0.75rem;
    }

    .hero-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.6rem;
        min-height: 58px;
        padding: 1rem 1.6rem;
        border: 1px solid var(--line-strong);
        background: rgba(255, 252, 244, 0.78);
        color: var(--text-white);
        font-family: var(--font-heading);
        font-size: 1.05rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease;
    }

    .hero-link:hover {
        transform: translateY(-2px);
        border-color: var(--brand-orange);
        background: rgba(250, 162, 39, 0.12);
    }

    .hero-link i {
        transition: transform 0.25s ease;
    }

    .hero-link:hover i {
        transform: translateX(4px);
    }

    .launch-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(250, 162, 39, 0.18);
        color: var(--brand-orange-deep);
        border: 1px solid rgba(184, 104, 0, 0.12);
        padding: 0.4rem 0.9rem;
        border-radius: 999px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-size: 0.8rem;
        margin-bottom: 1.5rem;
    }


    /* Staggered Entrance */
    .slide-in-1 { animation: slideUp 0.8s ease forwards; opacity: 0; animation-delay: 0.2s; }
    .slide-in-2 { animation: slideUp 0.8s ease forwards; opacity: 0; animation-delay: 0.4s; }
    .slide-in-3 { animation: slideUp 0.8s ease forwards; opacity: 0; animation-delay: 0.6s; }
    .slide-in-4 { animation: slideUp 0.8s ease forwards; opacity: 0; animation-delay: 0.8s; }
    .slide-in-5 { animation: slideUp 0.8s ease forwards; opacity: 0; animation-delay: 1s; }

    .hero-visual {
        position: relative;
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 1;
    }

    .circle-bg {
        position: absolute;
        width: 540px;
        height: 540px;
        background: radial-gradient(circle, rgba(250, 162, 39, 0.2) 0%, rgba(250, 162, 39, 0.06) 42%, transparent 72%);
        border-radius: 50%;
        z-index: -1;
        animation: pulse-glow 4s infinite ease-in-out;
    }

    .visual-stage {
        position: relative;
        padding: clamp(1rem, 2vw, 1.3rem);
        border-radius: 36px;
        background: linear-gradient(160deg, rgba(255, 252, 244, 0.7), rgba(255, 233, 183, 0.4));
        border: 1px solid rgba(71, 45, 6, 0.12);
        box-shadow: 0 30px 70px rgba(71, 45, 6, 0.14);
        backdrop-filter: blur(10px);
    }

    .hero-burger {
        width: min(100%, 560px);
        border-radius: 28px;
        border: 1px solid rgba(255, 255, 255, 0.3);
        box-shadow: 0 24px 60px rgba(0, 0, 0, 0.18);
        transform-origin: center center;
    }

    .float-card {
        position: absolute;
        right: -1rem;
        bottom: 1.5rem;
        background: rgba(255, 247, 229, 0.9);
        border: 1px solid rgba(71, 45, 6, 0.14);
        backdrop-filter: blur(10px);
        padding: 1rem 1.5rem;
        border-radius: 16px;
        display: flex;
        align-items: center;
        gap: 1rem;
        animation: float 5s ease-in-out infinite reverse;
    }

    .float-card .emoji { font-size: 2rem; }
    .float-card strong { display: block; color: var(--brand-orange-deep); font-size: 1.1rem; }
    .float-card small { color: var(--text-muted); text-transform: uppercase; font-size: 0.7rem; }

    @media (max-width: 900px) {
        .hero-wrapper {
            height: auto;
            min-height: 100svh;
        }

        .hero-grid {
            grid-template-columns: 1fr;
            padding-top: calc(var(--header-height) + 1.2rem);
            height: auto;
            min-height: auto;
            display: flex;
            flex-direction: column;
            justify-content: flex-start;
            padding-bottom: 3rem;
            gap: 2rem;
        }

        .overlay {
            background:
                linear-gradient(180deg, rgba(255, 248, 230, 0.96) 0%, rgba(255, 244, 214, 0.92) 65%, rgba(255, 241, 205, 0.68) 100%);
        }

        .hero-text {
            display: flex;
            flex-direction: column;
            align-items: center;
            z-index: 2;
            order: 1;
            width: 100%;
        }

        .hero-copy-shell {
            width: 100%;
            text-align: center;
            padding: 1.5rem;
            border-radius: 26px;
        }

        .hero-desc {
            margin: 0 auto 1.25rem;
            font-size: 1.05rem;
            padding: 0;
            max-width: 95%;
            line-height: 1.7;
        }

        .hero-highlights {
            justify-content: center;
        }

        .hero-actions {
            width: 100%;
            justify-content: center;
            padding: 0;
        }

        .hero-cta,
        .hero-link {
            width: min(100%, 320px);
        }

        .hero-visual {
            margin-top: 0;
            z-index: 1;
            order: 2;
        }

        .hero-burger {
            width: 100%;
            max-width: 360px;
        }

        .mega-title {
            font-size: clamp(3.6rem, 13vw, 4.8rem);
            margin-bottom: 1rem;
            line-height: 1.05;
        }

        .slide-in-1, .slide-in-2, .slide-in-3, .slide-in-4, .slide-in-5 {
            opacity: 0;
            animation: slideUp 0.6s ease forwards;
        }

        .slide-in-1 { animation-delay: 0.1s; }
        .slide-in-2 { animation-delay: 0.2s; }
        .slide-in-3 { animation-delay: 0.3s; }
        .slide-in-4 { animation-delay: 0.4s; }
        .slide-in-5 { animation-delay: 0.5s; }

        .float-card {
            right: 0.5rem;
            bottom: 0.8rem;
            padding: 0.5rem 0.75rem;
            font-size: 0.85rem;
        }

        .float-card .emoji {
            font-size: 1.5rem;
        }

        .circle-bg {
            width: 300px;
            height: 300px;
        }

        .scroll-indicator {
            display: none;
        }

        .launch-badge {
            font-size: 0.75rem;
            margin-bottom: 1rem;
        }
    }

    @media (max-width: 400px) {
        .mega-title {
            font-size: clamp(3.6rem, 14.5vw, 4.3rem);
        }

        .hero-burger {
            max-width: 290px;
        }
    }
</style>

<script>
    // Parallax Effect for Background and Burger
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const canHover = window.matchMedia('(hover: hover)').matches;

    if (!prefersReducedMotion && canHover) {
        document.addEventListener('mousemove', (e) => {
            const x = (window.innerWidth - e.pageX * 2) / 100;
            const y = (window.innerHeight - e.pageY * 2) / 100;

            const burger = document.querySelector('.hero-burger');
            // @ts-ignore
            if(burger) burger.style.transform = `translateX(${x}px) translateY(${y}px)`;
            
            const card = document.querySelector('.float-card');
            // @ts-ignore
            if(card) card.style.transform = `translateX(${-x}px) translateY(${-y}px)`;
        });
    }
</script>
