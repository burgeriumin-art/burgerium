---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Anatomy from '../components/Anatomy.astro';
import Menu from '../components/Menu.astro';
import Craft from '../components/Craft.astro';
import Reviews from '../components/Reviews.astro';
import Locations from '../components/Locations.astro';
import Footer from '../components/Footer.astro';
---

<Layout
    title="Burgerium | Nungambakkam, Chennai Burger House"
    description="Burgerium is opening in Nungambakkam, Chennai (E Merck House, Haddows 2nd Street, 600006). House-baked buns and flame-grilled burgers."
>
    <Navigation />
    <div class="page">
        <Hero />
        
        <!-- Loud Rolling Marquee (Restored & Moved Up) -->
        <div class="marquee-container">
            <div class="marquee">
                <span>Burgerium • Flagship Burger House</span>
                <span class="separator">✦</span>
                <span>Built on Craft Since 1998</span>
                <span class="separator">✦</span>
                <span>Hand-Baked Buns</span>
                <span class="separator">✦</span>
                <span>Flame-Grilled Patties</span>
                <span class="separator">✦</span>
                <span>Tharekkad • RS Puram • Race Course</span>
                <span class="separator">✦</span>
                <span>Chennai Launch • Burgerium</span>
            </div>
        </div>

        <About />
        <Craft />
        <Anatomy />
        <Menu />
        <Locations />
        <Reviews />
    </div>
    <Footer />
</Layout>

<style>
    /* Marquee Styles */
    .marquee-container {
        background: linear-gradient(180deg, #ffb037 0%, #f39d20 100%);
        color: #000;
        padding: 0.85rem 0;
        overflow: hidden;
        white-space: nowrap;
        position: relative;
        z-index: 10;
        border-top: 2px solid rgba(31, 22, 9, 0.22);
        border-bottom: 2px solid rgba(31, 22, 9, 0.22);
        transform: rotate(-1deg) scale(1.02);
        margin: -2.2rem 0 5rem 0;
        box-shadow: 0 18px 36px rgba(112, 71, 7, 0.12);
    }

    .marquee {
        display: inline-block;
        animation: marquee 20s linear infinite;
    }

    .marquee span {
        font-family: var(--font-heading);
        font-weight: 900;
        font-size: 1.9rem;
        text-transform: uppercase;
        margin: 0 1.6rem;
        letter-spacing: -1px;
        display: inline-flex;
        align-items: center;
        gap: 0.85rem;
    }

    .marquee span:nth-child(even) {
        -webkit-text-stroke: 1px #000;
        color: transparent;
    }

    .separator {
        display: none;
    }

    @media (max-width: 900px) {
        .marquee-container {
            transform: rotate(-1deg) scale(1.04);
            margin: -1rem 0 4rem 0;
            border-width: 2px;
            padding: 0.75rem 0;
            width: 100%;
            left: 0;
            margin-left: 0;
        }

        .marquee span {
            font-size: 1.2rem;
            margin: 0 1rem;
        }
    }

    @keyframes marquee {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
    }
</style>
